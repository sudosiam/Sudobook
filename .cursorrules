```

Import conventions:
```typescript
// Dexie
import { db } from '@/lib/db';
import { useLiveQuery } from 'dexie-react-hooks';

// Supabase (only in sync layer)
import { supabase } from '@/lib/supabase';

// Money
import { toPaise, toINR, addMoney, pct } from '@/lib/money';

// Accounting
import { postJournalEntry } from '@/lib/accounting';

// Icons — always named imports
import { Plus, ArrowLeft, TrendingUp } from 'lucide-react';

// Date
import { format, startOfMonth, endOfMonth } from 'date-fns';

// Router
import { useNavigate, useParams, Link } from 'react-router-dom';

// State
import { useAppStore } from '@/store/useAppStore';
```

Path alias `@/` maps to `src/`. Always use `@/` imports, never relative
paths like `../../lib/db`.

