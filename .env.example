# ─────────────────────────────────────────────────────────────
# Sudo Books — required environment variables
# Copy this file to .env (local dev) or set these in your
# Vercel / hosting dashboard (Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────

# Dexie Cloud database URL (enables cross-device sync + backup).
# Create a free database at https://dexie.cloud and paste the URL here.
# Without this variable, the app runs in local-only mode — all data
# stays on the device and cannot sync to other devices.
VITE_DEXIE_CLOUD_URL=https://YOUR-DB-ID.dexie.cloud
